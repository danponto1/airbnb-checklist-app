<!doctype html>
<html>
<head><meta charset="utf-8" /><title>Admin - Submissions</title></head>
<body style="font-family: Arial, sans-serif; margin: 24px;">
  <h1>Checklist Submissions</h1>
  <p><a href="/form">Open cleaner form</a> · <a href="/admin/logout">Log out</a></p>
  <table border="1" cellpadding="8" cellspacing="0">
    <thead>
      <tr>
        <th>ID</th><th>Property</th><th>Cleaner</th><th>Cleaning Date</th><th>Submitted At</th><th>View</th>
      </tr>
    </thead>
    <tbody>
      <% submissions.forEach(s => { %>
        <tr>
          <td><%= s.id %></td>
          <td><%= (schema.properties.find(p => p.id === s.property_id) || {}).name || s.property_id %></td>
          <td><%= s.cleaner_name %></td>
          <td><%= s.cleaning_date || '-' %></td>
          <td><%= s.created_at %></td>
          <td><a href="/admin/submissions/<%= s.id %>">Open</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</body>
</html>
